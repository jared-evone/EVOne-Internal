# Copy this file to .env and fill in real values for local development.
# In production, set these in the Render dashboard (declared in render.yaml).

# ---- Supabase ----
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# ---- DocuSeal ----
DOCUSEAL_API_KEY=
