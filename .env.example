# DOCUSEAL_BASE_URL=

# ---- DocuSeal template IDs (one per form variant) ----
TEMPLATE_ID_FORM_A_1P=
TEMPLATE_ID_FORM_A_2P=
TEMPLATE_ID_FORM_D_2P=
TEMPLATE_ID_FORM_D_3P=
TEMPLATE_ID_FORM_1_2P=
TEMPLATE_ID_FORM_1_3P=
